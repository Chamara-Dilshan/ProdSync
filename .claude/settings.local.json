{
  "permissions": {
    "allow": [
      "Bash(dir:*)",
      "Bash(git config:*)",
      "Bash(npm install:*)",
      "Bash(npm run dev:*)",
      "Bash(timeout /t 5)",
      "Bash(ping:*)",
      "Bash(ls:*)",
      "Bash(npm run lint)",
      "Bash(npm run format:check:*)",
      "Bash(npx husky init)",
      "Bash(npx storybook@latest init:*)",
      "Bash(git add:*)",
      "Bash(npm run type-check:*)",
      "Bash(if [ -f .env.local ])",
      "Bash(then echo \"Found .env.local\")",
      "Bash(else echo \"No .env.local file found. Checking .env.local.example...\")",
      "Bash(fi)",
      "Bash(powershell:*)",
      "Bash(git rm:*)"
    ]
  }
}
